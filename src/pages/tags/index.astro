---
import { getCollection } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";
import { toTagSlug } from "../../utils/tags";

const blogEntries = await getCollection("blog");
const counts = new Map<string, number>();

for (const entry of blogEntries) {
  for (const tag of entry.data.tags ?? []) {
    counts.set(tag, (counts.get(tag) ?? 0) + 1);
  }
}

const tags = [...counts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "zh-CN"));
---

<PageLayout title="标签" description="按主题归档现有文章。" canonicalPath="/tags/">
  <section class="section">
    <div class="section__title">
      <h2>Tags</h2>
      <p class="meta">{tags.length} 个标签</p>
    </div>
    <div class="tag-list">
      {tags.map(([tag, count]) => (
        <a class="tag" href={`/tags/${toTagSlug(tag)}/`}>{tag} · {count}</a>
      ))}
    </div>
  </section>
</PageLayout>

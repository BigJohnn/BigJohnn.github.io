---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 | 项目清单" description="页面不存在。" canonicalPath="/404.html">
  <main class="shell section">
    <section class="panel empty-state">
      <h1>页面不存在</h1>
      <p>这个地址可能已经失效，或者页面已被移动。</p>
      <div class="tag-list">
        <a class="tag" href="/">返回首页</a>
        <a class="tag" href="/blog/">查看文章</a>
        <a class="tag" href="/projects/">查看项目</a>
      </div>
    </section>
  </main>
</BaseLayout>

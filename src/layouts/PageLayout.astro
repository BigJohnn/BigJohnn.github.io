---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath } = Astro.props;
---

<BaseLayout title={`${title} | 项目清单`} description={description} canonicalPath={canonicalPath}>
  <main class="shell section">
    <slot />
  </main>
</BaseLayout>

---
interface ImageItem {
  src: string;
  alt: string;
}

interface Props {
  images: ImageItem[];
  columns?: 2 | 3 | 4;
  caption?: string;
  sizes?: string;
  eagerFirst?: boolean;
}

const {
  images,
  columns = 2,
  caption,
  sizes = columns === 4
    ? "(max-width: 760px) 50vw, 22vw"
    : columns === 3
      ? "(max-width: 760px) 50vw, 30vw"
      : "(max-width: 760px) 100vw, 48vw",
  eagerFirst = false
} = Astro.props;
---

<figure class="image-grid">
  <div class:list={["image-grid__items", `image-grid__items--${columns}`]}>
    {images.map((image, index) => (
      <img
        loading={eagerFirst && index === 0 ? "eager" : "lazy"}
        decoding="async"
        fetchpriority={eagerFirst && index === 0 ? "high" : "auto"}
        sizes={sizes}
        src={image.src}
        alt={image.alt}
      />
    ))}
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .image-grid {
    margin: 0 0 1.4rem;
    content-visibility: auto;
    contain-intrinsic-size: 480px;
  }

  .image-grid__items {
    display: grid;
    gap: 0.8rem;
  }

  .image-grid__items--2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .image-grid__items--3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .image-grid__items--4 {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .image-grid img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }

  .image-grid figcaption {
    margin-top: 0.65rem;
    color: var(--muted);
    font-size: 0.94rem;
  }

  @media (max-width: 760px) {
    .image-grid__items--4,
    .image-grid__items--3 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
